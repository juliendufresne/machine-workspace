# shellcheck source=lib/state.sh
source "$PROJECT_ROOT/lib/state.sh"
# shellcheck source=lib/output.sh
source "$PROJECT_ROOT/lib/output.sh"
# shellcheck source=lib/prompt.sh
source "$PROJECT_ROOT/lib/prompt.sh"
# shellcheck source=lib/gpg.sh
source "$PROJECT_ROOT/lib/gpg.sh"
# shellcheck source=lib/gitconfig.sh
source "$PROJECT_ROOT/lib/gitconfig.sh"
# shellcheck source=lib/workspace.sh
source "$PROJECT_ROOT/lib/workspace.sh"
# shellcheck source=libexec/manage-ssh-keys
source "$PROJECT_ROOT/libexec/manage-ssh-keys"

# ─── Execute ──────────────────────────────────────────────────────────────────
[[ "${BASH_SOURCE[0]}" != "$0" ]] || create::main "$@"
