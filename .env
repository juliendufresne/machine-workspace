# Tracked defaults for the Makefile (the dev toolbox image and the tool versions
# baked into it). Copy any line into an untracked .env.local to override it on
# your machine; both files are loaded, with .env.local taking precedence.
DEV_TOOL_IMAGE=workspace-dev-tools
UBUNTU_VERSION=26.04
SHELLCHECK_VERSION=0.11.0
SHELLSPEC_VERSION=0.28.1
